# ─── EANyra — environment variables ────────────────────────────────────────
# Copy this file to .env and fill in the values you want to override.
# All variables are optional; defaults are shown as comments.

# ── General ──────────────────────────────────────────────────────────────────

NODE_ENV=production          # development | production

# ── Scheduler ────────────────────────────────────────────────────────────────

# Standard 5-field cron expression (UTC).
CRON_SCHEDULE="0 8 * * *"   # default: every day at 08:00 UTC

# Set to true to run one scrape immediately on process start.
RUN_ON_STARTUP=false

# ── Database ─────────────────────────────────────────────────────────────────

# Absolute or cwd-relative path to the SQLite file.
DB_PATH=data/pot.sqlite

# ── Browser (Playwright) ──────────────────────────────────────────────────────

# Directory for the persistent browser profile (cookies live here).
BROWSER_DATA_PATH=data/nyra

# Headless mode (recommended for scraping).
# Use false for debugging / manual observation.
BROWSER_HEADLESS=true

# Timeouts in milliseconds.
BROWSER_NAV_TIMEOUT_MS=30000
BROWSER_SEL_TIMEOUT_MS=15000

# Browser fingerprint/region tuning.
BROWSER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/134.0.0.0 Safari/537.36
BROWSER_VIEWPORT_WIDTH=1280
BROWSER_VIEWPORT_HEIGHT=900
BROWSER_LOCALE=en-US
BROWSER_TIMEZONE=America/New_York
BROWSER_COOKIES_PATH=data/cookies.json

# Optional Twitter URL overrides.
# NOTE: project defaults are x.com URLs (see src/config/app.config.js).
TWITTER_LOGIN_URL=https://x.com
TWITTER_HOME_URL=https://x.com/home

# ── Scraper ───────────────────────────────────────────────────────────────────

# Posts to collect per account on a regular daily run.
POSTS_PER_ACCOUNT=20

# Posts to collect on the very first scrape of a new account.
INITIAL_POSTS_PER_ACCOUNT=200

# Base scroll delay (ms). Actual delay adds up to +1 000 ms of jitter.
SCROLL_DELAY_MS=2500

# Random gap between consecutive accounts (ms).
# Defaults to 5–15 minutes — keeps the session looking human.
MIN_DELAY_BETWEEN_ACCOUNTS_MS=300000    # 5 min
MAX_DELAY_BETWEEN_ACCOUNTS_MS=900000    # 15 min

# Safety cap: max scroll attempts before giving up on one profile.
MAX_SCROLL_ATTEMPTS=30

# Optional scraper-specific timeouts (override BROWSER_* defaults).
SCRAPER_NAV_TIMEOUT_MS=30000
SCRAPER_SELECTOR_TIMEOUT_MS=15000
